# Shared
APP_ENV=development

# Frontend
NEXT_PUBLIC_APP_NAME=Personal AI Task Manager
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Backend
APP_NAME=Personal AI Task Manager
APP_DEBUG=true
API_V1_PREFIX=/api/v1
